{
	"name": "buenos_cakes",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev": "concurrently -k -n api,web \"pnpm mock-api\" \"pnpm dev:web\"",
		"dev:e2e": "concurrently -k -n api,web \"pnpm mock-api\" \"NEXT_DIST_DIR=.next-e2e next dev --hostname 127.0.0.1 --port 3100\"",
		"dev:web": "next dev",
		"build": "next build",
		"start": "next start",
		"lint": "biome check",
		"format": "biome format --write",
		"mock-api": "json-server --watch db.json --port 3333 --host 127.0.0.1",
		"test:unit": "vitest run",
		"test:unit:watch": "vitest",
		"test:e2e": "playwright test",
		"test:e2e:ui": "playwright test --ui"
	},
	"dependencies": {
		"@hookform/resolvers": "^5.2.2",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"lucide-react": "^0.577.0",
		"motion": "^12.35.0",
		"next": "16.1.6",
		"nuqs": "^2.8.9",
		"radix-ui": "^1.4.3",
		"react": "19.2.3",
		"react-dom": "19.2.3",
		"react-hook-form": "^7.71.2",
		"react-resizable-panels": "^4.7.2",
		"tailwind-merge": "^3.5.0",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "2.2.0",
		"@playwright/test": "^1.58.2",
		"@tailwindcss/postcss": "^4",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@types/node": "^20",
		"@types/react": "^19",
		"@types/react-dom": "^19",
		"concurrently": "^9.2.1",
		"jsdom": "^28.1.0",
		"json-server": "1.0.0-beta.12",
		"shadcn": "^3.8.5",
		"tailwindcss": "^4",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5",
		"vitest": "^4.0.18"
	}
}
